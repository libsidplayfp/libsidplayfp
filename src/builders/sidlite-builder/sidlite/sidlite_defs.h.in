// Based on cRSID-1.56 by Hermit (Mihaly Horvath)

#define HAVE_BUILTIN_EXPECT @HAVE_BUILTIN_EXPECT@

#if HAVE_BUILTIN_EXPECT
#  define UNLIKELY(expression)  __builtin_expect(!!(expression), 0) //condition is unlikely to happen most of the times
#  define LIKELY(expression)    __builtin_expect(!!(expression), 1) //condition is likely to be true most of the times
#else
#  define UNLIKELY(expression)  (expression)
#  define LIKELY(expression)    (expression)
#endif

enum {
    SID_CHANNEL_SPACING = 7,
    SID_CHANNEL_COUNT = 3,
    CHANNEL2_INDEX = (2*SID_CHANNEL_SPACING),
    SID_CHANNELS_RANGE = (SID_CHANNEL_SPACING * SID_CHANNEL_COUNT)
};
